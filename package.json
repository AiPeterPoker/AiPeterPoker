{
  "name": "ai-in-peter",
  "version": "1.0.0",
  "description": "AI-IN Peter — Open-source AI poker agent for Casino Hold'em with Peter Griffin's overconfident personality",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "vite build && electron-builder",
    "backend": "cd backend && pip install -r requirements.txt --quiet && python server.py",
    "backend:install": "cd backend && pip install -r requirements.txt",
    "start": "concurrently \"npm run backend\" \"npm run dev\"",
    "test": "cd backend && python ../tests/test_engine.py",
    "preview": "vite preview"
  },
  "dependencies": {
    "dotenv": "^17.3.1",
    "electron-store": "^8.2.0",
    "framer-motion": "^11.0.0",
    "lucide-react": "^0.383.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.12.0",
    "screenshot-desktop": "^1.15.0",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "electron": "^29.1.0",
    "electron-builder": "^24.13.3",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.1",
    "vite": "^5.2.0",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.ai-in-peter.agent",
    "productName": "AI-IN Peter",
    "mac": {
      "target": "dmg"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    }
  },
  "author": "",
  "license": "MIT"
}
